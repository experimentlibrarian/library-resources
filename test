function renderBreadcrumb(){
  const dims=GAME_DATA.meta.dimensions;
  let h='<div class="breadcrumb" role="navigation" aria-label="Activity progress">';
  dims.forEach((d,i)=>{
    const done=i<state.activityIdx,current=i===state.activityIdx;
    h+='<div class="bc-step '+(done?'done':'')+' '+(current?'current':'')+'">';
    h+='<span class="bc-num" style="'+(done||current?'background:'+d.colour+';color:#fff;':'')+'">'+(done?'\u2713':(i+1))+'</span>';
    h+='<span class="bc-label">'+d.label+'</span></div>';
    if(i<dims.length-1)h+='<div class="bc-connector '+(done?'done':'')+'"></div>';
  });
  return h+'</div>';
}

