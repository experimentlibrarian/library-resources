<script>
const CLAIM_COLORS=['#2563EB','#DC2626','#059669','#D97706','#7C3AED'];
function getClaimColor(n){return CLAIM_COLORS[(n-1)%CLAIM_COLORS.length]}

/* ============================================================
   GLOBE OVERLAY
   ============================================================ */
let globeTrapHandler=null;
function openGlobe(num){
  const act=getActivity();
  if(!act)return;
  const q=act.questions.find(x=>x.num===num);
  if(!q||!q.tooltip)return;
  const color=getClaimColor(num);
  const ov=document.getElementById('globeOverlay');
  const panel=document.getElementById('globePanel');
  panel.style.setProperty('--globe-color',color);
  const badge=document.getElementById('globeBadge');
  badge.style.background=color;
  badge.textContent=num;
  const t=q.tooltip;
  document.getElementById('globeBody').innerHTML=
    '<div class="globe-section globe-look"><div class="globe-section-label">What to look for</div><p>'+t.look+'</p></div>'+
    '<div class="globe-section globe-check"><div class="globe-section-label">How to check it</div><p>'+t.check+'</p></div>'+
    '<div class="globe-section globe-why"><div class="globe-section-label">Why this matters</div><p>'+t.why+'</p></div>';
  state.globeClaimNum=num;
  ov.classList.add('show');
  document.body.style.overflow='hidden';
  const closeBtn=panel.querySelector('.globe-panel-close');
  closeBtn.focus();
  // Focus trap
  if(globeTrapHandler)panel.removeEventListener('keydown',globeTrapHandler);
  globeTrapHandler=function(e){
    if(e.key!=='Tab')return;
    const focusable=panel.querySelectorAll('button,[tabindex]:not([tabindex="-1"])');
    const first=focusable[0],last=focusable[focusable.length-1];
    if(e.shiftKey){if(document.activeElement===first){e.preventDefault();last.focus()}}
    else{if(document.activeElement===last){e.preventDefault();first.focus()}}
  };
  panel.addEventListener('keydown',globeTrapHandler);
}
function closeGlobe(e){if(e.target===document.getElementById('globeOverlay'))closeGlobeForce()}
function closeGlobeForce(){
  const ov=document.getElementById('globeOverlay');
  ov.classList.remove('show');
  document.body.style.overflow='';
  const num=state.globeClaimNum;
  if(num){
    // Return focus to triggering badge
    const badge=document.querySelector('.claim-badge[data-claim-num="'+num+'"]');
    if(badge)badge.focus();
    // Scroll matching question into view & pulse
    setTimeout(()=>{
      const card=document.querySelector('.question-card[data-claim-num="'+num+'"]');
      if(card){
        card.scrollIntoView({behavior:'smooth',block:'center'});
        card.classList.add('pulse-highlight');
        setTimeout(()=>card.classList.remove('pulse-highlight'),900);
      }
    },150);
  }
  state.globeClaimNum=null;
}

