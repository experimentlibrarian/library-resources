                        <body>
                            <!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Three Checks — Evaluate AI Outputs</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:16px;scroll-behavior:smooth}
body{font-family:'Lato','Helvetica Neue',Helvetica,Arial,sans-serif;background:#fff;color:#2D3B45;line-height:1.6;min-height:100vh}
button{font-family:inherit;cursor:pointer;border:none}
button:focus-visible,a:focus-visible,input:focus-visible,summary:focus-visible{outline:3px solid #2563EB;outline-offset:2px}
#app{max-width:1140px;margin:0 auto;padding:1.25rem 2rem;min-height:100vh}
h1{font-family:'Lato',sans-serif;font-weight:900;font-size:2rem;line-height:1.2;margin-bottom:.5rem}
h2{font-family:'Lato',sans-serif;font-weight:700;font-size:1.5rem;line-height:1.3;margin-bottom:.5rem}
h3{font-size:1.1rem;font-weight:700;margin-bottom:.5rem}
p{margin-bottom:.75rem}
.card{background:#F9FAFB;border:1px solid #E5E7EB;border-radius:12px;padding:1.5rem;margin-bottom:1rem}

/* ========== WELCOME ========== */
.welcome-header{text-align:center;padding:2rem 0 1rem}
.welcome-header h1{font-size:2.4rem;margin-bottom:.25rem}
.welcome-header .subtitle{font-size:1.15rem;color:#555;margin-bottom:1.5rem}
.welcome-intro{font-size:1.05rem;color:#444;text-align:center;margin-bottom:2rem;max-width:680px;margin-left:auto;margin-right:auto}
.pathway-grid{display:grid;gap:1rem;grid-template-columns:repeat(3,1fr)}
.pathway-btn{display:flex;flex-direction:column;align-items:flex-start;background:#fff;border:2px solid #E2E0DC;border-radius:12px;padding:1.25rem 1.5rem;text-align:left;transition:border-color .2s,box-shadow .2s,transform .15s}
.pathway-btn:hover,.pathway-btn:focus-visible{border-color:var(--pw-color);box-shadow:0 4px 12px rgba(0,0,0,.08);transform:translateY(-2px)}
.pathway-btn .pw-label{font-weight:900;font-size:1.3rem;margin-bottom:.25rem;color:var(--pw-color)}
.pathway-btn .pw-desc{font-size:.95rem;color:#555}

/* ========== BREADCRUMB ========== */
.breadcrumb{display:flex;align-items:center;gap:0;margin-bottom:1rem;padding:.75rem 1rem;background:#F9FAFB;border:1px solid #E5E7EB;border-radius:10px}
.bc-step{display:flex;align-items:center;gap:.35rem;flex:0 0 auto}
.bc-num{display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;border-radius:50%;font-size:.75rem;font-weight:700;background:#E5E7EB;color:#9CA3AF;flex-shrink:0}
.bc-label{font-size:.82rem;font-weight:600;color:#9CA3AF}
.bc-step.done .bc-num{color:#fff}
.bc-step.done .bc-label,.bc-step.current .bc-label{color:#2D3B45}
.bc-step.current .bc-num{color:#fff;box-shadow:0 0 0 3px rgba(0,0,0,.08)}
.bc-connector{flex:1;height:2px;background:#E5E7EB;margin:0 .5rem;min-width:.75rem}
.bc-connector.done{background:#059669}

/* ========== PROGRESS BAR ========== */
.progress-bar{display:flex;align-items:center;gap:.5rem;margin-bottom:.5rem;font-size:.85rem;color:#666}
.progress-track{flex:1;height:6px;background:#E2E0DC;border-radius:3px;overflow:hidden}
.progress-fill{height:100%;border-radius:3px;transition:width .4s ease}

/* ========== DIMENSION BADGE + TECHNIQUE ========== */
.check-header{display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;margin-bottom:.75rem}
.dim-badge{display:inline-flex;align-items:center;gap:.4rem;font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;padding:.3rem .75rem;border-radius:99px;color:#fff}
.dim-badge svg{width:16px;height:16px}
.technique-tag{display:inline-flex;align-items:center;font-size:.85rem;color:#6B7280;font-style:italic}
.technique-tag::before{content:'';display:inline-block;width:4px;height:4px;border-radius:50%;background:#9CA3AF;margin-right:.5rem}

/* ========== TASK PROMPT ========== */
.task-prompt{background:#FEFCE8;border-left:4px solid #D97706;padding:1rem 1.25rem;border-radius:0 8px 8px 0;margin-bottom:.75rem;font-size:1rem;font-weight:500}

/* ========== HOW-IT-WORKS (collapsible) ========== */
.hiw-details{margin-bottom:1rem;border:1px solid #E5E7EB;border-radius:10px;background:#F3F4F6;overflow:hidden}
.hiw-summary{display:flex;align-items:center;gap:.6rem;padding:.7rem 1rem;cursor:pointer;font-size:.9rem;font-weight:700;color:#2D3B45;list-style:none}
.hiw-summary::-webkit-details-marker{display:none}
.hiw-summary::after{content:'▸';margin-left:auto;transition:transform .2s;font-size:.8rem;color:#9CA3AF}
.hiw-details[open] .hiw-summary::after{transform:rotate(90deg)}
.hiw-icon{display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:50%;background:#2D3B45;color:#fff;font-size:.7rem;font-weight:700;flex-shrink:0}
.hiw-steps{padding:.25rem 1rem 1rem 1rem;margin:0}
.hiw-steps li{padding:.35rem 0;font-size:.88rem;color:#4B5563;line-height:1.5;margin-left:1.25rem}
.hiw-steps li::marker{font-weight:700;color:#2D3B45}

/* ========== GLOSSARY (collapsible) ========== */
.glossary-details{margin-bottom:1.25rem;border:1px solid #E5E7EB;border-radius:10px;background:#FAFAF8;overflow:hidden}
.glossary-summary{display:flex;align-items:center;gap:.6rem;padding:.65rem 1rem;cursor:pointer;font-size:.85rem;font-weight:700;color:#6B7280;list-style:none}
.glossary-summary::-webkit-details-marker{display:none}
.glossary-summary::after{content:'▸';margin-left:auto;transition:transform .2s;font-size:.8rem;color:#9CA3AF}
.glossary-details[open] .glossary-summary::after{transform:rotate(90deg)}
.glossary-list{padding:.5rem 1rem 1rem;margin:0;display:grid;grid-template-columns:1fr 1fr;gap:.1rem .75rem}
.glossary-list dt{font-weight:700;font-size:.85rem;color:#2D3B45;padding-top:.5rem}
.glossary-list dd{font-size:.85rem;color:#555;margin:0;padding-bottom:.5rem;border-bottom:1px solid #EDEDEC}

/* ========== ACTIVITY COLUMNS ========== */
.activity-columns{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;align-items:start}
.activity-col-chat{position:sticky;top:1.25rem}
.col-header{display:flex;align-items:flex-start;gap:.65rem;margin-bottom:.75rem;padding-bottom:.6rem;border-bottom:2px solid #E5E7EB}
.col-step{display:inline-flex;align-items:center;justify-content:center;width:30px;height:30px;border-radius:50%;background:#2D3B45;color:#fff;font-size:.85rem;font-weight:700;flex-shrink:0}
.col-step.step-done{background:#059669}
.col-title{font-size:1rem;font-weight:700;color:#2D3B45;line-height:1.3}
.col-hint{font-size:.85rem;color:#6B7280;margin-top:.2rem;line-height:1.45}

/* ========== MOBILE COLUMN DIVIDER ========== */
.mobile-divider{display:none;text-align:center;padding:1rem 0;color:#9CA3AF;font-size:.85rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em}
.mobile-divider::before,.mobile-divider::after{content:'';display:inline-block;width:2rem;height:1px;background:#D1D5DB;vertical-align:middle;margin:0 .5rem}

/* ========== CLAIM ANCHOR ========== */
.claim-anchor{display:inline;position:relative}
.claim-text{border-bottom:2px dashed transparent;background-color:transparent;padding:0 1px;border-radius:2px;transition:border-bottom-color .2s,background-color .2s}
.claim-anchor.is-active .claim-text,.claim-anchor:hover .claim-text,.claim-anchor:focus-within .claim-text{border-bottom-color:var(--claim-color);background-color:color-mix(in srgb,var(--claim-color) 10%,transparent)}
.claim-badge{display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;border-radius:50%;background:var(--claim-color);color:#fff;font-size:.82rem;font-weight:700;vertical-align:middle;margin-left:.4rem;cursor:pointer;border:2px solid transparent;transition:transform .18s,box-shadow .18s,border-color .18s;flex-shrink:0;user-select:none;line-height:1;position:relative}
.claim-badge:hover,.claim-badge:focus-visible,.claim-anchor.is-active .claim-badge{transform:scale(1.15);box-shadow:0 3px 10px rgba(0,0,0,.18);border-color:rgba(255,255,255,.6)}
.claim-badge.in-card{margin-left:0;margin-right:.65rem}
.claim-badge.anchor-floating{margin-left:.4rem;vertical-align:middle}

/* ========== GLOBE OVERLAY ========== */
.globe-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:500;align-items:center;justify-content:center;padding:1.5rem}
.globe-overlay.show{display:flex}
.globe-panel{background:#fff;border-radius:14px;padding:2rem 2.25rem;max-width:540px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,.18),0 2px 8px rgba(0,0,0,.08);position:relative;border-top:5px solid var(--globe-color,#2563EB)}
.globe-panel-close{position:absolute;top:.85rem;right:.85rem;width:32px;height:32px;border-radius:50%;background:#F3F4F6;color:#6B7280;font-size:1.1rem;display:flex;align-items:center;justify-content:center;transition:background .15s,color .15s}
.globe-panel-close:hover{background:#E5E7EB;color:#2D3B45}
.globe-badge-lg{display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:50%;background:var(--globe-color,#2563EB);color:#fff;font-size:1.1rem;font-weight:700;margin-bottom:1rem}
.globe-section{padding:.7rem 1rem;border-left:3px solid #E5E7EB;margin-bottom:.65rem;border-radius:0 6px 6px 0;background:#F9FAFB}
.globe-section:last-child{margin-bottom:0}
.globe-section-label{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.25rem}
.globe-section p{margin:0;font-size:.95rem;line-height:1.6;color:#2D3B45}
.globe-look{border-left-color:#2563EB}
.globe-look .globe-section-label{color:#2563EB}
.globe-check{border-left-color:#059669}
.globe-check .globe-section-label{color:#059669}
.globe-why{border-left-color:#D97706}
.globe-why .globe-section-label{color:#D97706}

/* ========== QUESTION CARD ========== */
.q-card-header{display:flex;align-items:flex-start;margin-bottom:.65rem}
.question-card{background:#FAFAF8;border:1.5px solid #E2E0DC;border-radius:10px;padding:1.15rem;margin-bottom:.85rem;transition:transform .18s,box-shadow .18s,border-color .18s}
.question-card.is-active{transform:translateY(-2px);box-shadow:0 6px 18px rgba(0,0,0,.10);border-color:var(--claim-color,#2D3B45)}
.question-card.correct{border-color:#059669;background:#ECFDF5}
.question-card.incorrect{border-color:#DC2626;background:#FEF2F2}
.question-card.pulse-highlight{animation:pulseCard .8s ease-out}
@keyframes pulseCard{0%{box-shadow:0 0 0 0 rgba(37,99,235,.35)}70%{box-shadow:0 0 0 12px rgba(37,99,235,0)}100%{box-shadow:none}}
.question-text{font-size:.97rem;font-weight:600;line-height:1.45}
.option-group{display:flex;flex-wrap:wrap;gap:.5rem}
.option-btn{padding:.5rem 1rem;border-radius:8px;font-size:.9rem;font-weight:500;background:#fff;border:1.5px solid #CCC;color:#333;transition:all .15s}
.option-btn:hover{border-color:#888}
.option-btn.selected{background:#1A1A2E;color:#fff;border-color:#1A1A2E}
.option-btn:disabled{opacity:.7;cursor:default}
.option-btn.selected.is-correct{background:#059669;border-color:#059669}
.option-btn.selected.is-incorrect{background:#DC2626;border-color:#DC2626}
.option-btn.show-correct:not(.selected){border-color:#059669;border-width:2.5px}
.option-btn.multi{position:relative;padding-left:2rem}
.option-btn.multi::before{content:'';position:absolute;left:.6rem;top:50%;transform:translateY(-50%);width:16px;height:16px;border:2px solid #999;border-radius:3px;background:#fff}
.option-btn.multi.selected::before{background:#1A1A2E;border-color:#1A1A2E}
.option-btn.multi.selected::after{content:'\2713';position:absolute;left:.7rem;top:50%;transform:translateY(-55%);color:#fff;font-size:.75rem;font-weight:700}
.option-btn.multi.selected.is-correct::before{background:#059669;border-color:#059669}
.option-btn.multi.selected.is-incorrect::before{background:#DC2626;border-color:#DC2626}
.option-btn.multi.show-correct:not(.selected)::before{border-color:#059669;border-width:2.5px}
.q-feedback{margin-top:.65rem;padding:.65rem .85rem;border-radius:6px;font-size:.9rem;line-height:1.55;display:none}
.q-feedback.show{display:block}
.q-feedback.correct-fb{background:#ECFDF5;color:#065F46}
.q-feedback.incorrect-fb{background:#FEF2F2;color:#991B1B}

/* ========== BUTTONS ========== */
.btn-row{display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1rem;align-items:center}
.btn-primary{display:inline-flex;align-items:center;gap:.5rem;padding:.75rem 1.75rem;border-radius:10px;font-size:1rem;font-weight:600;background:#1A1A2E;color:#fff;transition:background .2s,transform .1s}
.btn-primary:hover{background:#2D2D44}
.btn-primary:active{transform:scale(.97)}
.btn-primary:disabled{background:#999;cursor:not-allowed}
.btn-secondary{display:inline-flex;align-items:center;gap:.5rem;padding:.75rem 1.75rem;border-radius:10px;font-size:1rem;font-weight:600;background:transparent;color:#1A1A2E;border:2px solid #CCC;transition:all .2s}
.btn-secondary:hover{border-color:#1A1A2E}
.btn-next{display:inline-flex;align-items:center;gap:.5rem;padding:.75rem 1.75rem;border-radius:10px;font-size:.95rem;font-weight:600;background:#F3F4F6;color:#6B7280;border:2px solid #D1D5DB;transition:all .2s}
.btn-next:hover{background:#E5E7EB;color:#374151;border-color:#9CA3AF}
.btn-back{display:inline-flex;align-items:center;gap:.4rem;padding:.65rem 1.1rem;border-radius:10px;font-size:.9rem;font-weight:600;background:transparent;color:#6B7280;border:1.5px solid #D1D5DB;transition:all .2s}
.btn-back:hover{color:#2D3B45;border-color:#6B7280;background:#F9FAFB}
.btn-back .arrow{font-size:1rem;line-height:1}

/* ========== CHAT BUBBLES ========== */
.chat-container{margin-bottom:1.5rem}
.chat-turn{display:flex;flex-direction:column;margin-bottom:.75rem}
.chat-turn.student{align-items:flex-start}
.chat-turn.ai{align-items:flex-end}
.chat-label{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.25rem;padding:0 .5rem}
.chat-turn.student .chat-label{color:#2563EB}
.chat-turn.ai .chat-label{color:#6B21A8}
.chat-bubble{max-width:95%;padding:1rem 1.15rem;border-radius:12px;font-size:.95rem;line-height:1.7;white-space:pre-line}
.chat-turn.student .chat-bubble{background:#E8EDF2;border-bottom-left-radius:4px}
.chat-turn.ai .chat-bubble{background:#fff;border:1.5px solid #E2E0DC;border-bottom-right-radius:4px;overflow:visible}

/* ========== REFLECTION SCREEN ========== */
.reflection-screen{padding:2rem 0}
.reflection-card{max-width:1040px;margin:0 auto;background:#F9FAFB;border:1px solid #E5E7EB;border-radius:12px;padding:2rem}
.checks-progress{display:flex;align-items:center;gap:0;margin-bottom:1.5rem;padding:1rem;background:#fff;border:1px solid #E5E7EB;border-radius:10px}
.check-pip{display:flex;align-items:center;gap:.4rem;flex:0 0 auto}
.pip-icon{display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;border-radius:50%;flex-shrink:0;font-size:.8rem;font-weight:700;background:#E5E7EB;color:#9CA3AF}
.check-pip.done .pip-icon{background:#059669;color:#fff}
.check-pip.current .pip-icon{box-shadow:0 0 0 3px rgba(5,150,105,.2)}
.pip-label{font-size:.85rem;font-weight:600;color:#9CA3AF}
.check-pip.done .pip-label{color:#2D3B45}
.pip-connector{flex:1;height:2px;background:#E5E7EB;margin:0 .5rem;min-width:1rem}
.pip-connector.done{background:#059669}
.scaffold-oneliner{font-size:1.1rem;font-weight:700;line-height:1.45;border-left:4px solid var(--dim-color,#2D3B45);padding:.75rem 1rem;margin-bottom:1.5rem;background:#fff;border-radius:0 8px 8px 0}
.scaffold-bridge{font-size:.9rem;color:#6B7280;font-style:italic;padding:.85rem 0 .25rem;margin-top:.75rem}
.reflection-prompts{list-style:none;padding:0;margin:0}
.reflect-zone-top{padding-bottom:1.25rem}
.reflect-zone-read{background:#EFF6FF;border:1px solid #BFDBFE;border-radius:10px;padding:1.25rem;margin-bottom:.75rem}
.reflect-zone-share{background:#ECFDF5;border:1px solid #A7F3D0;border-radius:10px;padding:1.25rem}
.prompts-step-header{display:flex;align-items:center;gap:.6rem;font-size:.95rem;font-weight:700;color:#2D3B45;margin-bottom:.85rem}
.step-num{display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;border-radius:50%;flex-shrink:0;font-size:.75rem;font-weight:700;background:#2D3B45;color:#fff}
.reflect-zone-read .step-num{background:#2563EB}
.reflect-zone-share .step-num{background:#059669}
.reflection-prompts li{padding:.85rem 1rem .85rem 3rem;margin-bottom:.5rem;background:#fff;border:1px solid #D1D5DB;border-radius:8px;font-size:.95rem;line-height:1.55;position:relative}
.reflection-prompts li:last-child{margin-bottom:0}
.reflection-prompts li::before{content:'\201C';position:absolute;left:.6rem;top:.5rem;width:24px;height:24px;border-radius:50%;background:var(--dim-color,#2D3B45);color:#fff;font-size:.9rem;font-weight:700;font-family:Georgia,serif;display:flex;align-items:center;justify-content:center}

/* ========== TIP CALLOUT ========== */
.tip-callout{margin-top:1rem;padding:1rem 1.25rem;background:#FFFBEB;border:1px solid #FDE68A;border-radius:10px;border-left:4px solid #D97706}
.tip-callout-label{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#D97706;margin-bottom:.3rem}
.tip-callout p{margin:0;font-size:.92rem;line-height:1.55;color:#2D3B45}

/* ========== SUMMARY ========== */
.summary-header{text-align:center;padding:2rem 0 1rem}
.dim-card{display:flex;gap:1rem;align-items:flex-start;padding:1.15rem;border-radius:10px;margin-bottom:.75rem;border-left:4px solid var(--dim-color);background:#fff}
.dim-card svg{width:28px;height:28px;flex-shrink:0;margin-top:.15rem}
.dim-card .dim-name{font-weight:700;font-size:1rem;margin-bottom:.15rem}
.dim-card .dim-question{font-size:.95rem;color:#444}

/* ========== FACILITATOR ========== */
.facilitator-toggle{position:fixed;bottom:1rem;right:1rem;padding:.5rem .85rem;border-radius:8px;font-size:.75rem;background:#1A1A2E;color:#fff;opacity:.5;z-index:100;transition:opacity .2s}
.facilitator-toggle:hover{opacity:1}
.facilitator-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;display:none;overflow-y:auto}
.facilitator-overlay.show{display:block}
.facilitator-panel{max-width:800px;margin:2rem auto;background:#fff;border-radius:12px;padding:2rem;position:relative}
.facilitator-panel h2{margin-bottom:1rem}
.facilitator-panel h3{margin-top:1.5rem;color:#555}
.facilitator-panel ul{padding-left:1.25rem;margin-bottom:1rem}
.facilitator-panel li{margin-bottom:.5rem;font-size:.95rem}
.facilitator-close{position:absolute;top:1rem;right:1rem;width:36px;height:36px;border-radius:50%;background:#F0F0F0;font-size:1.2rem;display:flex;align-items:center;justify-content:center}

/* ========== REDUCED MOTION ========== */
@media(prefers-reduced-motion:reduce){
  .fade-in{animation:none!important}
  .globe-panel{animation:none!important}
  .question-card.pulse-highlight{animation:none!important}
  *{transition-duration:.01ms!important}
}

/* ========== PRINT ========== */
@media print{
  body{background:#fff}
  #app{max-width:100%;padding:1rem}
  .btn-row,.facilitator-toggle,.progress-bar,.no-print,.breadcrumb,.hiw-details,.glossary-details{display:none!important}
  .card{border:1px solid #ddd;break-inside:avoid}
  .claim-text{border-bottom:1px solid #888!important;background:none!important}
}
/* ========== RESPONSIVE ========== */
@media(max-width:900px){
  .activity-columns{grid-template-columns:1fr}
  .activity-col-chat{position:static}
  .pathway-grid{grid-template-columns:1fr}
  .mobile-divider{display:block}
  .glossary-list{grid-template-columns:1fr}
}
@media(max-width:600px){
  #app{padding:.85rem}
  h1{font-size:1.75rem}
  h2{font-size:1.3rem}
  .welcome-header h1{font-size:2rem}
  .chat-bubble{max-width:96%;font-size:.9rem}
  .option-group{flex-direction:column}
  .option-btn,.option-btn.multi{width:100%;text-align:left}
  .btn-row{flex-direction:column;align-items:stretch}
  .btn-primary,.btn-secondary,.btn-back,.btn-next{width:100%;justify-content:center}
  .facilitator-panel{margin:1rem;padding:1.25rem}
  .checks-progress{flex-wrap:wrap;gap:.35rem;justify-content:center}
  .pip-connector{display:none}
  .globe-panel{padding:1.5rem;margin:.5rem}
  .bc-label{font-size:.72rem}
  .bc-connector{min-width:.4rem}
}
.fade-in{animation:fadeIn .35s ease}
