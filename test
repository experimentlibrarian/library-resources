const app=document.getElementById('app');
let state={screen:'welcome',pathwayId:null,activityIdx:0,answers:{},submitted:false,activeClaim:null,globeClaimNum:null};
function getPathway(){return GAME_DATA.pathways.find(p=>p.id===state.pathwayId)}
function getActivity(){return getPathway()?.activities[state.activityIdx]}
function getDimension(dimId){return GAME_DATA.meta.dimensions.find(d=>d.id===dimId)}
function dimIcon(dimId,size=20){
  const i={
    'answer':'<svg width="'+size+'" height="'+size+'" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>',
    'reasoning':'<svg width="'+size+'" height="'+size+'" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
    'behaviour':'<svg width="'+size+'" height="'+size+'" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>'
  };return i[dimId]||''
}
function isCorrect(q,a){
  if(q.type==='multi_select'){if(!Array.isArray(a))return false;const c=[...q.correct].sort(),b=[...a].sort();return c.length===b.length&&c.every((v,i)=>v===b[i])}
  return a===q.correct
}
function scrollTop(){window.scrollTo({top:0,behavior:'smooth'})}
function escapeHtml(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}
function escapeAttr(s){return s.replace(/'/g,"\\'").replace(/"/g,'&quot;')}

