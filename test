/* ============================================================
   RENDER CHAT TURN TEXT
   ============================================================ */
function renderTurnText(turn,turnIndex,questions){
  let h=escapeHtml(turn.text);
  questions.forEach(q=>{
    if(!q.highlight_text)return;
    const escaped=escapeHtml(q.highlight_text);
    if(h.includes(escaped)){
      const color=getClaimColor(q.num);
      const ariaText=q.text.replace(/"/g,'&quot;');
      const wrap='<span class="claim-anchor" data-claim-num="'+q.num+'" style="--claim-color:'+color+'">'+
        '<span class="claim-text">'+escaped+'</span>'+
        '<button class="claim-badge" data-claim-num="'+q.num+'" tabindex="0" aria-label="Check '+q.num+': '+ariaText+'" onclick="event.stopPropagation();openGlobe('+q.num+')">'+q.num+'</button></span>';
      h=h.replace(escaped,wrap);
    }
  });
  questions.forEach(q=>{
    if(q.highlight_text)return;
    if(q.anchor_turn===turnIndex){
      const color=getClaimColor(q.num);
      const ariaText=q.text.replace(/"/g,'&quot;');
      h+=' <span class="claim-anchor" data-claim-num="'+q.num+'" style="--claim-color:'+color+'">'+
        '<button class="claim-badge anchor-floating" data-claim-num="'+q.num+'" tabindex="0" aria-label="Check '+q.num+': '+ariaText+'" onclick="event.stopPropagation();openGlobe('+q.num+')">'+q.num+'</button></span>';
    }
  });
  return h;
}

/* ============================================================
   RENDER: ACTIVITY
   ============================================================ */
function renderActivity(){
  const pw=getPathway(),act=getActivity(),dim=getDimension(act.dimension);
  const progress=(state.activityIdx/pw.activities.length)*100;
  let h='<div class="fade-in">';
  // Breadcrumb
  h+=renderBreadcrumb();
  // Progress bar
  h+='<div class="progress-bar no-print"><span>'+pw.title+'</span><div class="progress-track"><div class="progress-fill" style="width:'+progress+'%;background:'+pw.colour+'"></div></div><span>Activity '+act.number+' of '+pw.activities.length+'</span></div>';
  // Dimension badge
  h+='<div class="check-header"><div class="dim-badge" style="background:'+dim.colour+'">'+dimIcon(dim.id,16)+' '+dim.label+'</div>';
  if(act.technique)h+='<span class="technique-tag">'+act.technique+'</span>';
  h+='</div>';
  // Task
  h+='<div class="task-prompt">'+act.task+'</div>';
  // How-it-works (collapsible, open by default)
  h+='';
  // Glossary
  h+=renderGlossary();
  // Two columns
  h+='<div class="activity-columns">';
  // Left: chat
  h+='<div class="activity-col-chat"><div class="col-header"><span class="col-step '+(state.submitted?'step-done':'')+'">1</span><div><div class="col-title">Read the conversation</div><div class="col-hint">Click the numbered markers to see what to check.</div></div></div>'+
    '<div class="chat-container card">';
  act.conversation.forEach((turn,idx)=>{
    h+='<div class="chat-turn '+turn.role+'"><span class="chat-label">'+(turn.role==='student'?'Student':'AI')+'</span>'+
      '<div class="chat-bubble">'+renderTurnText(turn,idx,act.questions)+'</div></div>';
  });
  h+='</div></div>';
  // Mobile divider
  h+='<div class="mobile-divider">Now answer the questions</div>';
  // Right: questions
  h+='<div class="activity-col-questions"><div class="col-header"><span class="col-step">2</span><div><div class="col-title">Answer each numbered question</div><div class="col-hint">Each card matches a numbered marker in the conversation.</div></div></div><div class="questions-section">';
  act.questions.forEach(q=>{
    const answered=state.answers[q.id],sub=state.submitted;
    const correct=sub?isCorrect(q,answered):null;
    const cardClass=sub?(correct?'correct':'incorrect'):'';
    const color=getClaimColor(q.num);
    h+='<div class="question-card '+cardClass+'" data-claim-num="'+q.num+'" style="--claim-color:'+color+'">';
    h+='<div class="q-card-header"><span class="claim-badge in-card" data-claim-num="'+q.num+'" style="--claim-color:'+color+'" onclick="openGlobe('+q.num+')" tabindex="0" role="button" aria-label="Check '+q.num+': '+q.text.replace(/"/g,'&quot;')+'">'+q.num+'</span><div class="question-text">'+q.text+'</div></div>';
    h+='<div class="option-group">';
    if(q.type==='multi_select'){
      q.options.forEach(opt=>{
        const sel=Array.isArray(answered)&&answered.includes(opt);
        const isC=q.correct.includes(opt);
        let cls='option-btn multi';
        if(sel)cls+=' selected';
        if(sub&&sel&&isC)cls+=' is-correct';
        if(sub&&sel&&!isC)cls+=' is-incorrect';
        if(sub&&!sel&&isC)cls+=' show-correct';
        h+='<button class="'+cls+'" '+(sub?'disabled':'')+' onclick="toggleMulti(\''+q.id+'\',\''+escapeAttr(opt)+'\')">'+opt+'</button>';
      });
    }else{
      q.options.forEach(opt=>{
        const sel=answered===opt;
        let cls='option-btn';
        if(sel)cls+=' selected';
        if(sub&&sel&&opt===q.correct)cls+=' is-correct';
        if(sub&&sel&&opt!==q.correct)cls+=' is-incorrect';
        if(sub&&!sel&&opt===q.correct)cls+=' show-correct';
        h+='<button class="'+cls+'" '+(sub?'disabled':'')+' onclick="selectOption(\''+q.id+'\',\''+escapeAttr(opt)+'\')">'+opt+'</button>';
      });
    }
    h+='</div>';
    if(sub){
      const fbClass=correct?'correct-fb':'incorrect-fb';
      h+='<div class="q-feedback show '+fbClass+'">'+(correct?'\u2713 ':'\u2717 ')+q.feedback+'</div>';
    }
    h+='</div>';
  });
  h+='</div>';
  // Buttons
  h+='<div class="btn-row">';
  if(!state.submitted){
    const allA=act.questions.every(q=>{const a=state.answers[q.id];if(q.type==='multi_select')return Array.isArray(a)&&a.length>0;return a!==undefined});
    h+='<button class="btn-primary" '+(allA?'':'disabled')+' onclick="submitAnswers()">Check my answers</button>';
  }else{
    h+='<button class="btn-primary" onclick="nextStep()">Continue</button>';
  }
  h+='</div></div></div></div>';
  app.innerHTML=h;
  setupClaimInteractions();
}

/* ============================================================
   CLAIM INTERACTIONS
   ============================================================ */
function setupClaimInteractions(){
  document.querySelectorAll('[data-claim-num]').forEach(el=>{
    const num=el.dataset.claimNum;
    el.addEventListener('mouseenter',()=>activatePair(num));
    el.addEventListener('mouseleave',()=>deactivatePair(num));
    el.addEventListener('focusin',()=>activatePair(num));
    el.addEventListener('focusout',()=>deactivatePair(num));
  });
  document.querySelectorAll('.question-card[data-claim-num]').forEach(card=>{
    card.addEventListener('click',e=>{
      if(e.target.closest('.option-btn'))return;
      scrollToHighlight(card.dataset.claimNum);
    });
  });
}
function activatePair(n){
  document.querySelectorAll('[data-claim-num="'+n+'"]').forEach(el=>{
    if(el.classList.contains('claim-anchor'))el.classList.add('is-active');
    if(el.classList.contains('question-card'))el.classList.add('is-active');
  });
}
function deactivatePair(n){
  document.querySelectorAll('[data-claim-num="'+n+'"]').forEach(el=>el.classList.remove('is-active'));
}
function scrollToHighlight(n){
  const anchor=document.querySelector('.claim-anchor[data-claim-num="'+n+'"]');
  if(anchor){anchor.scrollIntoView({behavior:'smooth',block:'center'});anchor.classList.add('is-active');setTimeout(()=>anchor.classList.remove('is-active'),1500)}
}

/* ============================================================
   REFLECTION SCAFFOLDING
   ============================================================ */
const REFLECTION_SCAFFOLDING=[
  {
    heading:"You\u2019ve completed your first check",checksCompleted:1,
    oneLiner:"AI outputs mix accurate and inaccurate information \u2014 and both can look equally convincing.",
    prompts:[
      "What clues helped you tell the real source from the fake one \u2014 and what made it tricky?",
      "The AI gave a real fact but fabricated a source. Why might AI do this, and what does it tell you about relying on AI\u2019s information?",
      "Next time you get information from AI, what\u2019s the first thing you would check?"
    ],
    bridge:"You\u2019ve learned to check what AI produces. Next, you\u2019ll see what happens when a student catches a mistake and asks AI to fix it.",
    tip:null
  },
  {
    heading:"You now have two checks",checksCompleted:2,
    oneLiner:"Spotting a problem is only half the job. You also need to judge whether AI\u2019s response to your feedback actually solves it.",
    prompts:[
      "The AI apologised and offered a replacement. What looked like a fix but wasn\u2019t?",
      "The AI used flattery and contradicted its earlier advice instead of being direct. Why might AI avoid telling you it can\u2019t help?",
      "If you pushed back on an AI response and got a confident-sounding answer, how would you decide whether the problem is actually resolved?"
    ],
    bridge:"You can now check the output and the behaviour. Next, you\u2019ll see what effective AI use actually looks like.",
    tip:null
  },
  {
    heading:"You now have all three checks",checksCompleted:3,
    oneLiner:"You\u2019ve seen AI at its worst and its best. The difference isn\u2019t just what it says \u2014 it\u2019s how it works with you.",
    prompts:[
      "The AI said \u201cI can\u2019t search the database for you\u201d and gave search terms instead. How is this different from the earlier activities where it generated sources directly?",
      "What specific AI behaviours helped the student move forward \u2014 and what behaviours in the earlier activities held them back?",
      "When you next use AI, what would make you trust an interaction more \u2014 and what would make you stop and question it?"
    ],
    bridge:null,
    tip:{label:"Workshop tip",text:"Your librarian can help with search strategy, database selection, and finding sources for your specific topic. If you\u2019re unsure where to start, that\u2019s exactly what they\u2019re there for."}
  }
];

/* ============================================================
   RENDER: DISCUSSION
   ============================================================ */
function renderDiscussion(){
  const pw=getPathway(),scaffold=REFLECTION_SCAFFOLDING[state.activityIdx],dims=GAME_DATA.meta.dimensions;
  const isLast=state.activityIdx>=pw.activities.length-1,currentDim=dims[scaffold.checksCompleted-1];
  let h='<div class="fade-in reflection-screen"><div class="reflection-card"><div class="reflect-zone-top">';
  // Breadcrumb in reflection too
  h+=renderBreadcrumb();
  h+='<h2 style="margin-bottom:1.25rem">'+scaffold.heading+'</h2><div class="checks-progress">';
  dims.forEach((d,i)=>{
    const done=i<scaffold.checksCompleted,current=i===scaffold.checksCompleted-1;
    h+='<div class="check-pip '+(done?'done':'')+' '+(current?'current':'')+'"><span class="pip-icon">'+(done?'\u2713':(i+1))+'</span><span class="pip-label">'+d.label+'</span></div>';
    if(i<dims.length-1)h+='<div class="pip-connector '+(i<scaffold.checksCompleted-1?'done':'')+'"></div>';
  });
  h+='</div><p class="scaffold-oneliner" style="--dim-color:'+currentDim.colour+'">'+scaffold.oneLiner+'</p></div>';
  h+='<div class="reflect-zone-read"><div class="prompts-step-header"><span class="step-num">1</span> Read and reflect on the following questions</div>'+
    '<ul class="reflection-prompts" style="--dim-color:'+currentDim.colour+'">';
  scaffold.prompts.forEach(p=>{h+='<li>'+p+'</li>'});
  h+='</ul></div>';
  h+='<div class="reflect-zone-share"><div class="prompts-step-header"><span class="step-num">2</span> Pick one you\u2019d like to share your thoughts on in the Teams chat</div></div>';
  // Tip callout
  if(scaffold.tip){
    h+='<div class="tip-callout"><div class="tip-callout-label">'+scaffold.tip.label+'</div><p>'+scaffold.tip.text+'</p></div>';
  }
  if(scaffold.bridge)h+='<div class="scaffold-bridge">'+scaffold.bridge+'</div>';
  h+='<div class="btn-row" style="margin-top:1rem"><button class="btn-back" onclick="backToActivity()"><span class="arrow">\u2190</span> Back to activity</button>'+
    '<button class="btn-next" onclick="advanceActivity()">'+(isLast?'See summary':'Next check')+'</button></div>';
  h+='</div></div>';
  app.innerHTML=h;
}

/* ============================================================
   RENDER: SUMMARY
   ============================================================ */
function renderSummary(){
  const m=GAME_DATA.meta;
  let h='<div class="fade-in"><div class="summary-header"><h1>Well done!</h1><p style="color:#555;font-size:1.05rem;margin-top:.5rem">Here are three questions to ask yourself every time you use AI for your university work.</p></div>'+
    '<div class="card" id="takeaway-card"><h2 style="margin-bottom:1rem">'+m.takeaway.title+'</h2>';
  m.takeaway.checks.forEach((c,i)=>{
    const dim=m.dimensions[i];
    h+='<div class="dim-card" style="--dim-color:'+dim.colour+'"><div style="color:'+dim.colour+'">'+dimIcon(dim.id,28)+'</div><div><div class="dim-name" style="color:'+dim.colour+'">'+c.dimension+'</div><div class="dim-question">'+c.question+'</div></div></div>';
  });
  h+='</div><div class="btn-row" style="justify-content:center;flex-wrap:wrap"><button class="btn-primary" onclick="window.print()">Print this takeaway</button><button class="btn-secondary" onclick="restart()">Start over</button></div></div>';
  app.innerHTML=h;
}

/* ============================================================
   FACILITATOR
   ============================================================ */
function renderFacilitator(){
  const fn=GAME_DATA.facilitatorNotes;
  let h='<h2>Facilitator Answer Key</h2><p style="color:#666;margin-bottom:1.5rem">Patterns to highlight during group discussion.</p>';
  [fn.activity1Pattern,fn.activity2Pattern,fn.activity3Pattern].forEach(pat=>{
    h+='<h3>'+pat.title+'</h3><ul>';pat.notes.forEach(n=>{h+='<li>'+n+'</li>'});h+='</ul>';
  });
  GAME_DATA.pathways.forEach(pw=>{
    h+='<h3 style="margin-top:2rem;color:'+pw.colour+'">'+pw.title+' \u2014 All Answers</h3>';
    pw.activities.forEach(act=>{
      h+='<p style="font-weight:600;margin-top:1rem">Activity '+act.number+': '+act.dimensionLabel+'</p><ul>';
      act.questions.forEach(q=>{
        const ans=Array.isArray(q.correct)?q.correct.join(', '):q.correct;
        h+='<li><strong>'+q.text+'</strong><br>Answer: '+ans+'</li>';
      });h+='</ul>';
    });
  });
  document.getElementById('facContent').innerHTML=h;
}
function toggleFacilitator(){
  const ov=document.getElementById('facOverlay'),showing=ov.classList.toggle('show');
  if(showing)renderFacilitator();
  document.body.style.overflow=showing?'hidden':'';
}

/* ============================================================
   EVENT HANDLERS
   ============================================================ */
function selectPathway(id){state.pathwayId=id;state.activityIdx=0;state.answers={};state.submitted=false;state.screen='activity';render()}
function selectOption(qId,val){if(state.submitted)return;state.answers[qId]=val;render()}
function toggleMulti(qId,val){
  if(state.submitted)return;
  if(!state.answers[qId])state.answers[qId]=[];
  const arr=state.answers[qId],idx=arr.indexOf(val);
  if(idx>-1)arr.splice(idx,1);else arr.push(val);render()
}
function submitAnswers(){state.submitted=true;render();scrollTop()}
function nextStep(){state.screen='discussion';render();scrollTop()}
function backToActivity(){state.screen='activity';render();scrollTop()}
function advanceActivity(){
  const pw=getPathway();
  if(state.activityIdx<pw.activities.length-1){state.activityIdx++;state.answers={};state.submitted=false;state.activeClaim=null;state.screen='activity'}
  else{state.screen='summary'}
  render();scrollTop()
}
function restart(){state={screen:'welcome',pathwayId:null,activityIdx:0,answers:{},submitted:false,activeClaim:null,globeClaimNum:null};render();scrollTop()}
function render(){
  switch(state.screen){
    case'welcome':renderWelcome();break;
    case'activity':renderActivity();break;
    case'discussion':renderDiscussion();break;
    case'summary':renderSummary();break;
  }
}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeGlobeForce()});
render();
</script>
